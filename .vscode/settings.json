{
    "workbench.colorCustomizations": {
        "activityBar.background": "#15158E",
        "titleBar.activeBackground": "#1E1EC7",
        "titleBar.activeForeground": "#FCFCFF",
        "titleBar.inactiveBackground": "#15158E",
        "titleBar.inactiveForeground": "#FCFCFF",
        "statusBar.background": "#15158E",
        "statusBar.foreground": "#FCFCFF",
        "statusBar.debuggingBackground": "#15158E",
        "statusBar.debuggingForeground": "#FCFCFF",
        "statusBar.noFolderBackground": "#15158E",
        "statusBar.noFolderForeground": "#FCFCFF"
    },
    "editor.quickSuggestions": {
        "other": false,
        "comments": false,
        "strings": false
    },
    "editor.suggestOnTriggerCharacters": false,
    "editor.acceptSuggestionOnEnter": "off",
    "editor.acceptSuggestionOnCommitCharacter": false,
    "editor.inlineSuggest.enabled": false,
    "editor.wordBasedSuggestions": "off",
    "editor.tabCompletion": "off",

    // GitHub Copilot (AI completions)
    "github.copilot.enable": {
        "*": false
    }
}